{
  "name": "PrivateDiaryApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "bundle-android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "buildDebug-android": "cd android && ./gradlew clean && cd .. && react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle && cd android && ./gradlew assembleDebug && cd ..",
    "buildRelease-android": "cd android && ./gradlew clean && cd .. && react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle && cd android && ./gradlew assembleRelease && cd ..",
    "adb-log": "adb logcat *:E",
    "run-release": "adb -s emulator-5554 install android/app/build/outputs/apk/release/app-armeabi-v7a-release.apk"
  },
  "dependencies": {
    "@eva-design/eva": "^2.2.0",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.0.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@robinbobin/react-native-google-drive-api-wrapper": "^2.2.6",
    "@ui-kitten/components": "^5.3.1",
    "@ui-kitten/eva-icons": "^5.3.1",
    "crypto-es": "^3.1.3",
    "dayjs": "^1.11.13",
    "formik": "^2.4.6",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.7",
    "mobx-state-tree": "^7.0.0",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-calendars": "^1.1307.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "^2.21.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.3.0",
    "react-native-svg": "^15.9.0",
    "react-native-worklets": "^0.8.3",
    "realm": "20.2.0",
    "uuid": "^14.0.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@react-native/typescript-config": "0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^5.15.0",
    "@typescript-eslint/parser": "^5.15.0",
    "@ui-kitten/metro-config": "5.3.1",
    "eslint": "^8.19.0",
    "eslint-plugin-jest": "^28.6.0",
    "eslint-plugin-testing-library": "^7.0.0",
    "jest": "^29.6.3",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "yarn-audit-fix": "^10.1.0"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
